.venv/
__pycache__/
.pytest_cache/
.pytest_cache/*
*.pyc

# Local model artifacts are large and board-specific.
models/asr/*
models/tts/*
models/llm/*
!models/asr/.gitkeep
!models/tts/.gitkeep
!models/llm/.gitkeep

# Optional upstream source caches for board builds.
vendor/ax_asr_api/*
vendor/ax_tts_api/*
!vendor/.gitkeep
!vendor/ax_asr_api/
!vendor/ax_asr_api/.gitkeep
!vendor/ax_tts_api/
!vendor/ax_tts_api/.gitkeep

# Optional Home Assistant runtime data.
homeassistant/config/
